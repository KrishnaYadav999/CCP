PORT=8081
MONGO_PROVIDER=local
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/ccp
MONGO_ATLAS_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?appName=Cluster0
# Optional override for production platforms. If set, this wins over MONGO_PROVIDER.
MONGO_URI=
DB_NAME=ccp
CLIENT_ORIGIN=http://localhost:8080,http://localhost:5173,https://ccp-henna.vercel.app
JWT_SECRET=change-this-secret

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_SYNC_PASSWORD=false

# Optional. Set this when other CRM projects fetch CCP data.
CCP_SHARED_API_KEY=

# Optional. Used for CRM <-> CCP user sync.
# CRM -> CCP calls POST /api/crm/users/sync on this app.
# CCP -> CRM posts user create/update to CRM_USER_SYNC_URL.
CRM_SHARED_SECRET=
CCP_SHARED_SECRET=
CRM_USER_SYNC_URL=http://localhost:5000/api/auth/ccp/users/sync

# Optional. CCP -> CRM pending approval upsert/status sync.
CRM_PENDING_APPROVAL_SYNC_URL=http://localhost:5000/api/pending-approvals/ccp/sync
PENDING_APPROVAL_DIGEST_MINUTES=10
