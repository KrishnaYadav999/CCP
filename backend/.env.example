PORT=8081
MONGO_PROVIDER=local
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/ccp
MONGO_ATLAS_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?appName=Cluster0
# Optional override for production platforms. If set, this wins over MONGO_PROVIDER.
MONGO_URI=
DB_NAME=ccp
CLIENT_ORIGIN=http://localhost:8080,http://localhost:6173,http://localhost:6000,https://ccp-henna.vercel.app,https://crm-1-eight.vercel.app,https://crm-1-n88d.vercel.app
CRM_API_BASE_URL=http://localhost:6000/api
CRM_FRONTEND_URL=http://localhost:6173
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=change-this-secret

# Required for hosted OTP email delivery. For Brevo, use smtp-relay.brevo.com
# with port 587 or 2525 and MAIL_USER/MAIL_PASS from SMTP credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
ADMIN_SYNC_PASSWORD=false

# Optional. Set this when other CRM projects fetch CCP data.
CCP_SHARED_API_KEY=

# Optional. Used for CRM <-> CCP user sync.
# CRM -> CCP calls POST /api/crm/users/sync on this app.
# CCP -> CRM posts user create/update to CRM_USER_SYNC_URL.
CRM_SHARED_SECRET=
CCP_SHARED_SECRET=
CRM_USER_SYNC_URL=http://localhost:6000/api/crm/users/sync

# Optional. CCP -> CRM pending approval upsert/status sync.
CRM_PENDING_APPROVAL_SYNC_URL=http://localhost:6000/api/pending-approvals/ccp/sync
PENDING_APPROVAL_DIGEST_MINUTES=10
CCP_API_KEY=replace-with-a-strong-shared-secret

# Required for all user-uploaded images, videos, and documents.
# Keep API secret server-side only; configure the same variables in production.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CCP_CLOUDINARY_CLOUD_NAME=
CCP_CLOUDINARY_API_KEY=
CCP_CLOUDINARY_API_SECRET=
